---
import '../styles/normalize.css';
import '../styles/fonts.css';
import '../styles/global.css';
import Header from '../components/Header/Header.component.astro';
import Footer from '../components/Footer/Footer.component.astro';
import themeScript from '../utils/theme-script.js';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'CodeHelp';
const fullTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const metaDescription = description || 'A Discord Community for Web Development, Programming, and Marketing.';
const ogImage = '/images/codehelp-og-image.jpg';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Tom Gooden" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content="https://codehelp.io" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@good3n" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Google Analytics -->
    <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', import.meta.env.PUBLIC_GA_ID);
    </script>

    <!-- prevent FOUC -->
    <script is:inline set:html={themeScript} />
  </head>
  <body>
    <div class="container">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
